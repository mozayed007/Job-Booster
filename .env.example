# Job_Booster Environment Variables
#
# Prerequisites:
#   - Python >= 3.10
#   - Node.js >= 18 (required by LiteParse for PDF/document parsing)
#     Install LiteParse CLI: npm install -g @llamaindex/liteparse
#
# Model Selection:
#   The ModelRegistry auto-detects available providers from API keys below.
#   Set DEFAULT_MODEL to override, or leave empty for auto-detection.
#   Fallback chain: primary → remaining providers → Ollama (local).

# =================================================
# LLM API Keys (set any combination)
# =================================================

# OpenAI (GPT-4o, GPT-4o-mini, o1, etc.)
OPENAI_API_KEY=

# Anthropic (Claude Sonnet, Claude Opus)
ANTHROPIC_API_KEY=

# Google Gemini (Gemini 2.0 Flash, Gemini 1.5 Pro, etc.)
GEMINI_API_KEY=
# Alternative name (both work):
GOOGLE_API_KEY=

# Groq (fast inference for Llama, Mixtral)
GROQ_API_KEY=

# Together AI (Llama, Mixtral, CodeLlama)
TOGETHER_API_KEY=

# OpenRouter (access 100+ models via one API key)
OPENROUTER_API_KEY=

# =================================================
# Model Override (optional)
# =================================================

# Pydantic AI model string format: "provider:model-name"
# Examples:
#   openai:gpt-4o
#   anthropic:claude-sonnet-4-5
#   google:gemini-3.1-flash-lite
#   groq:llama-3.3-70b-versatile
#   ollama:llama3.2
#   openrouter:anthropic/claude-sonnet-4-5
DEFAULT_MODEL=
FALLBACK_MODEL=

# Set to true to prefer local Ollama over cloud APIs
PREFER_LOCAL=false

# =================================================
# Ollama (Local LLMs — Free, no API key needed)
# =================================================

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
# Other good models: qwen2.5, mistral, phi3, gemma2, codellama

# =================================================
# vLLM (Self-hosted high-throughput inference)
# =================================================

VLLM_BASE_URL=http://localhost:8001
VLLM_MODEL=default

# =================================================
# Observability (Logfire by Pydantic)
# =================================================

# Get your token at: https://logfire.pydantic.dev
LOGFIRE_TOKEN=

# =================================================
# Observability (Langfuse — optional, self-hosted)
# =================================================

# Get your keys at: https://cloud.langfuse.com or your self-hosted instance
# All three must be set to enable Langfuse tracing.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# =================================================
# Web Scraping
# =================================================

# TinyFish API (primary scraper — free Fetch tier)
TINYFISH_API_KEY=
USE_CRAWL4AI=false

# =================================================
# Database
# =================================================

DATABASE_URL=sqlite:///./job_booster.db

# =================================================
# Application
# =================================================

HOST=0.0.0.0
PORT=8000
API_URL=http://localhost:8000
LOG_LEVEL=INFO
DEBUG=False

# Comma-separated list of allowed origins, or "*" for all
# When using Next.js frontend on :3000, set explicit origins to enable credentials:
# CORS_ORIGINS=http://localhost:3000,http://localhost:8050
CORS_ORIGINS=*

# =================================================
# Authentication
# =================================================

# Auto-generated if not set, but set a fixed value for production
JWT_SECRET_KEY=
JWT_EXPIRY_HOURS=24

# =================================================
# Embeddings
# =================================================

# Model for vector embeddings (defaults to provider's embedding model)
EMBEDDING_MODEL=

# =================================================
# LiteLLM Settings
# =================================================

LITELLM_VERBOSE=false
LITELLM_CACHE=true

# =================================================
# Paths (defaults work for standard project layout)
# =================================================

# RESUME_SOURCES_DIR=data/resumes/sources
# RESUME_OUTPUT_DIR=data/resumes/output
# RESUME_TEMPLATE_PATH=data/templates/resume_template.tex
# STARTUPS_FILE_PATH=data/startups/startups.md
# JOBS_DIR=data/jobs
# GEMINI_MODEL=google:gemini-3.1-flash-lite

# =================================================
# BigSet (external dataset imports)
# =================================================
# Drop CSV/XLSX exports from https://github.com/tinyfish-io/bigset here
# USER_PROFILE_PATH=data/user_profile.yaml
# BIGSET_IMPORT_DIR=data/bigset_imports
# BIGSET_DEFAULT_MAPPING=generic_job_listing
# BIGSET_SKIP_SCRAPE_HOURS=0
# BIGSET_FOLDER_WATCH_ENABLED=true
# BIGSET_FOLDER_WATCH_CRON=0 */6 * * *
# BIGSET_MAX_UPLOAD_BYTES=52428800
# BIGSET_REMOTE_ENABLED=false
# BIGSET_APP_URL=http://localhost:3500
# BIGSET_AUTO_SYNC_ON_PIPELINE=true
# AX_MCPS_DIR=mcps
# AX_MERGE_INBOUND_MCPS=true
