# Job_Booster Environment Variables
#
# Prerequisites:
#   - Python >= 3.10
#   - Node.js >= 18 (required by LiteParse for PDF/document parsing)
#     Install LiteParse CLI: npm install -g @llamaindex/liteparse
#
# Model Selection:
#   The ModelRegistry auto-detects available providers from API keys below.
#   Set DEFAULT_MODEL to override, or leave empty for auto-detection.
#   Fallback chain: primary → remaining providers → Ollama (local).

# =================================================
# LLM API Keys (set any combination)
# =================================================

# OpenAI (GPT-4o, GPT-4o-mini, o1, etc.)
OPENAI_API_KEY=

# Anthropic (Claude Sonnet, Claude Opus)
ANTHROPIC_API_KEY=

# Google Gemini (Gemini 2.0 Flash, Gemini 1.5 Pro, etc.)
GEMINI_API_KEY=
# Alternative name (both work):
GOOGLE_API_KEY=

# Groq (fast inference for Llama, Mixtral)
GROQ_API_KEY=

# Together AI (Llama, Mixtral, CodeLlama)
TOGETHER_API_KEY=

# OpenRouter (access 100+ models via one API key)
OPENROUTER_API_KEY=

# =================================================
# Model Override (optional)
# =================================================

# Pydantic AI model string format: "provider:model-name"
# Examples:
#   openai:gpt-4o
#   anthropic:claude-sonnet-4-5
#   google-gla:gemini-2.0-flash
#   groq:llama-3.3-70b-versatile
#   ollama:llama3.2
#   openrouter:anthropic/claude-sonnet-4-5
DEFAULT_MODEL=
FALLBACK_MODEL=

# Set to true to prefer local Ollama over cloud APIs
PREFER_LOCAL=false

# =================================================
# Ollama (Local LLMs — Free, no API key needed)
# =================================================

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
# Other good models: qwen2.5, mistral, phi3, gemma2, codellama

# =================================================
# vLLM (Self-hosted high-throughput inference)
# =================================================

VLLM_BASE_URL=http://localhost:8001
VLLM_MODEL=default

# =================================================
# Observability (Logfire by Pydantic)
# =================================================

# Get your token at: https://logfire.pydantic.dev
LOGFIRE_TOKEN=

# =================================================
# Web Scraping
# =================================================

# TinyFish API (primary scraper — free Fetch tier)
TINYFISH_API_KEY=
USE_CRAWL4AI=false

# =================================================
# Database
# =================================================

DATABASE_URL=sqlite:///./job_booster.db

# =================================================
# Application
# =================================================

API_URL=http://localhost:8000
LOG_LEVEL=INFO
DEBUG=False
