# Job_Booster Environment Variables
# Copy this file to .env and fill in the values.

# -----------------------------------------------------------------------
# Google Gemini / ADK Configuration (Required for LLM features)
# -----------------------------------------------------------------------
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# -----------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
DEBUG=False

# -----------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------
DATABASE_URL=sqlite:///./job_booster.db

# -----------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------------
# Frontend (Gradio) — used by frontend.py when calling the backend API
# -----------------------------------------------------------------------
API_URL=http://localhost:8000
