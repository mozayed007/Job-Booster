# Agentic experience (AX) — commit these; do not add mcps/ or profiles/
# mcps/     inbound MCP tool schemas (GitHub, Notion, Supabase, …) for agents on this repo
# profiles/ portable agent profiles + outbound MCP server (profiles/runtimes/mcp_server.py)

# Generated output resumes (user-specific, do not commit)
data/resumes/output/*
!data/resumes/output/.gitkeep

# Vector DB data (runtime-generated)
data/qdrant/
data/chromadb/

# Node
node_modules/

# Scraper-generated job data (JSON postings)
data/jobs/*.json

# BigSet CSV/XLSX exports (local datasets; keep folder via .gitkeep)
data/bigset_imports/*
!data/bigset_imports/.gitkeep
